connector CSConnector {
  role requester(j) = process -> req!j -> res?j -> Skip;
  role responder() = req?j -> invoke -> process -> res!j -> responder();
}

component GroupBridge {
  port brg_call_cmp() = brg_cmp_req -> brg_call_cmp();
  port brg_call_cor() = brg_cor_req -> brg_call_cor();
  port brg_call_flt() = brg_flt_req -> brg_call_flt();
  port brg_call_iox() = brg_iox_req -> brg_call_iox();
  port brg_call_non() = brg_non_req -> brg_call_non();
  port brg_call_nbr() = brg_nbr_req -> brg_call_nbr();
  port brg_call_rem() = brg_rem_req -> brg_call_rem();
  port brg_call_seg() = brg_seg_req -> brg_call_seg();
  port brg_call_tpx() = brg_tpx_req -> brg_call_tpx();
  port brg_call_vid() = brg_vid_req -> brg_call_vid();
  port brg_srv_reg() = brg_reg_resp -> brg_srv_reg();
  port brg_srv_rem() = brg_rem_resp -> brg_srv_rem();
  port brg_srv_seg() = brg_seg_resp -> brg_srv_seg();
  port brg_srv_vid() = brg_vid_resp -> brg_srv_vid();
}

